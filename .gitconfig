[user]
	# Sanitized — set these locally with:
	#   git config --global user.name  "Your Name"
	#   git config --global user.email "you@example.com"
	name = Your Name
	email = you@example.com
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	light = false
[merge]
	conflictstyle = zdiff3
